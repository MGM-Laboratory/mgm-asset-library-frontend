# =========================================================================
# Public — exposed to the browser (must be prefixed NEXT_PUBLIC_)
# =========================================================================

NEXT_PUBLIC_APP_NAME="MGM Asset Library"
NEXT_PUBLIC_APP_URL=https://asset.labmgm.org
NEXT_PUBLIC_API_URL=https://asset-api.labmgm.org
NEXT_PUBLIC_WS_URL=wss://asset-api.labmgm.org/ws

NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,id

# Community external links (Navbar > Community dropdown)
NEXT_PUBLIC_COMMUNITY_DOCS_URL=https://docs.labmgm.org
NEXT_PUBLIC_COMMUNITY_LEARNING_URL=https://learn.labmgm.org
NEXT_PUBLIC_COMMUNITY_HELP_URL=https://help.labmgm.org

# Development-only: synthesize an authenticated admin session without Keycloak.
# MUST be empty/false in production. The runtime refuses to honor this when
# NODE_ENV === 'production'.
NEXT_PUBLIC_AUTH_MOCK=false

# Sentry — leave DSN blank to disable the SDK.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_AUTH_TOKEN=

# =========================================================================
# Server-only — Auth.js / Keycloak
# =========================================================================

NEXTAUTH_URL=https://asset.labmgm.org
NEXTAUTH_SECRET=please-generate-a-32-plus-character-secret

KEYCLOAK_CLIENT_ID=mgm-asset-library-web
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=https://auth.labmgm.org/realms/mgm
KEYCLOAK_LOGOUT_REDIRECT=https://asset.labmgm.org

# Session lifetime in seconds (default 30 days; matches backend).
SESSION_MAX_AGE_SECONDS=2592000

# OpenAPI generation source. Override to point at a running backend.
OPENAPI_SOURCE=../mgm-asset-library-backend/openapi.json
